// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bts {
  id             Int      @id @default(autoincrement())
  slNo           Int?
  airtelCode     String?
  robiCode       String?
  siteType       String?
  district       String?
  thana          String?
  address        String?
  securityVendor String?
  serviceType    String?
  posts          Int?
  persons        Int?
  deploymentDate String?
  guardNames     String?
  inchargeNames  String?
  remarks        String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("bts")
}
